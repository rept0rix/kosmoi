{
    "crons": [
        {
            "path": "/api/cron/agent-tick",
            "schedule": "*/10 * * * *"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/((?!api/)(?!.*\\.).*)",
            "destination": "/index.html"
        }
    ]
}