# syntax = docker/dockerfile:1
# ============================================================
# Kosmoi Agent Worker - Cloud Deployment (Minimal Image)
# ============================================================

FROM node:22-slim

WORKDIR /app

# Install git (needed for worker features)
RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y git ca-certificates && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Install PRODUCTION deps only (~1.2GB vs 2.5GB full)
COPY package.json ./
RUN npm install --omit=dev --ignore-scripts 2>&1 | tail -5

# Copy source code (node_modules excluded via .dockerignore)
COPY . .

# Fix git ownership warning
RUN git config --global --add safe.directory /app || true

ENV NODE_ENV=production
ENV PORT=8080

EXPOSE 8080

CMD ["node", "scripts/worker_start.js"]
